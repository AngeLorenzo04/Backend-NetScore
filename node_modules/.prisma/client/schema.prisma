datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid()) @map("id")
  nickname      String         @unique
  email         String         @unique
  passwordHash  String
  avatarUrl     String?        @map("avatar_url")
  leagueMembers LeagueMember[]
  predictions   Prediction[]

  @@map("users")
}

model League {
  id              String         @id @default(uuid()) @map("id")
  name            String
  inviteCode      String         @unique
  scoringStrategy String         @default("CLASSIC") // e.g., "CLASSIC", "ELASTIC"
  leagueMembers   LeagueMember[]
  predictions     Prediction[]

  @@map("leagues")
}

model LeagueMember {
  userId      String @map("user_id")
  leagueId    String @map("league_id")
  totalPoints Int    @default(0)

  user   User   @relation(fields: [userId], references: [id])
  league League @relation(fields: [leagueId], references: [id])

  @@id([userId, leagueId])
  @@map("league_members")
}

enum MatchStatus {
  SCHEDULED
  IN_PLAY
  FINISHED
}

model Match {
  id        String      @id @map("id") // Assuming match IDs are external, e.g., from a sports API
  homeTeam  String
  awayTeam  String
  startTime DateTime
  status    MatchStatus @default(SCHEDULED)
  homeGoals Int?
  awayGoals Int?

  predictions Prediction[]

  @@map("matches")
}

model Prediction {
  id            String @id @default(uuid()) @map("id")
  predictedHome Int
  predictedAway Int
  pointsEarned  Int?

  userId   String @map("user_id")
  matchId  String @map("match_id")
  leagueId String @map("league_id")

  user   User   @relation(fields: [userId], references: [id])
  match  Match  @relation(fields: [matchId], references: [id])
  league League @relation(fields: [leagueId], references: [id])

  @@unique([userId, matchId, leagueId])
  @@map("predictions")
}
